# .devcontainer/Dockerfile.dev
#
# Lightweight dev container for editor tooling, linting, and running tests.
# Does NOT include CUDA or NVDEC — the GPU services run as separate Compose
# services using their own Dockerfiles.
#
# GStreamer Python bindings are included so Pylance can resolve imports and
# mypy can type-check pipeline code, but NVDEC elements won't be available.
# Use `scripts/run-in-service.sh frame-reader` to exec into the GPU container
# when you need to test the actual NVDEC pipeline.

FROM python:3.11-slim-bookworm

# System deps: GStreamer Python bindings + build tools for uv
RUN apt-get update && apt-get install -y --no-install-recommends \
    # GStreamer — for import resolution and type checking only
    gstreamer1.0-tools \
    gstreamer1.0-plugins-base \
    gstreamer1.0-plugins-good \
    python3-gi \
    gir1.2-gstreamer-1.0 \
    gir1.2-gst-plugins-base-1.0 \
    # Build tools
    curl \
    git \
    bash \
    make \
    && rm -rf /var/lib/apt/lists/*

# Install uv — fast Python package manager
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.cargo/bin:/root/.local/bin:$PATH"

WORKDIR /workspace
